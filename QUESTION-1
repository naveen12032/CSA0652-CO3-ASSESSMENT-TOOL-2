#include <stdio.h>
typedef struct {
    int transactionID;
    int timestamp;
} Transaction;
void merge(Transaction arr[], int l, int m, int r) {
    int n1 = m - l + 1, n2 = r - m;
    Transaction L[n1], R[n2];
    for (int i = 0; i < n1; i++)
        L[i] = arr[l + i];
    for (int j = 0; j < n2; j++)
        R[j] = arr[m + 1 + j];
    int i = 0, j = 0, k = l;
    while (i < n1 && j < n2) {
        if (L[i].timestamp <= R[j].timestamp)
            arr[k++] = L[i++];   // Stable sorting
        else
            arr[k++] = R[j++];
    }
    while (i < n1)
        arr[k++] = L[i++];

    while (j < n2)
        arr[k++] = R[j++];
}

void mergeSort(Transaction arr[], int l, int r) {
    if (l < r) {
        int m = (l + r) / 2;

        mergeSort(arr, l, m);
        mergeSort(arr, m + 1, r);

        merge(arr, l, m, r);
    }
}

int main() {
    int n;

    printf("Enter number of transactions: ");
    scanf("%d", &n);

    Transaction t[n];

    printf("Enter Transaction ID and Timestamp:\n");

    for (int i = 0; i < n; i++) {
        scanf("%d %d",
              &t[i].transactionID,
              &t[i].timestamp);
    }

    mergeSort(t, 0, n - 1);

    printf("\nSorted Transactions:\n");

    printf("Transaction ID\tTimestamp\n");

    for (int i = 0; i < n; i++) {
        printf("%d\t\t%d\n",
               t[i].transactionID,
               t[i].timestamp);
    }

    return 0;
}
